{
  "name": "codenix-backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "worker": "tsx src/worker.ts",
    "build": "tsc",
    "start": "tsx dist/server.js",
    "typecheck": "tsc --noEmit",
    "seed:problems": "tsx prisma/seed-problems.ts",
    "seed:admin": "tsx prisma/seed-admin.ts",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "test": "cross-env NODE_ENV=test DOTENV_CONFIG_PATH=.env.test tsx src/tests/migrate-test-db.ts && cross-env NODE_ENV=test DOTENV_CONFIG_PATH=.env.test vitest run --fileParallelism=false",
    "test:watch": "cross-env NODE_ENV=test DOTENV_CONFIG_PATH=.env.test tsx src/tests/migrate-test-db.ts && cross-env NODE_ENV=test DOTENV_CONFIG_PATH=.env.test vitest",
    "test:coverage": "cross-env NODE_ENV=test DOTENV_CONFIG_PATH=.env.test tsx src/tests/migrate-test-db.ts && cross-env NODE_ENV=test DOTENV_CONFIG_PATH=.env.test vitest run --fileParallelism=false --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "tsx": "^4.22.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "4.1.9",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
